/* 腧穴列表页面样式 */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.p-6 {
  padding: 24rpx;
}

.mx-auto {
  margin-left: auto;
  margin-right: auto;
}

.mb-6 {
  margin-bottom: 24rpx;
}

.text-2xl {
  font-size: 32rpx;
}

.font-bold {
  font-weight: bold;
}

.text-gray-800 {
  color: #1f2937;
}

.text-gray-600 {
  color: #6b7280;
}

.text-sm {
  font-size: 24rpx;
}

.font-semibold {
  font-weight: 600;
}

.border {
  border: 1rpx solid;
}

.border-gray-200 {
  border-color: #e5e7eb;
}

.px-3 {
  padding-left: 12rpx;
  padding-right: 12rpx;
}

.py-2 {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.text-left {
  text-align: left;
}

.whitespace-normal {
  white-space: normal;
}

.hover-bg-gray-50:hover {
  background-color: #f9fafb;
}

.w-1-5 {
  width: 20%;
}

.w-3-5 {
  width: 60%;
}

.w-1-4 {
  width: 25%;
}

.w-2-4 {
  width: 50%;
}

.bg-blue-50 {
  background-color: #eff6ff;
}

.bg-green-50 {
  background-color: #f0fdf4;
}

.bg-yellow-50 {
  background-color: #fffbeb;
}

.shadow-sm {
  box-shadow: 0 1rpx 2rpx 0 rgba(0, 0, 0, 0.05);
}

.rounded-lg {
  border-radius: 12rpx;
}

.overflow-x-auto {
  overflow-x: auto;
}

.w-full {
  width: 100%;
}

.border-collapse {
  border-collapse: collapse;
}

.bg-white {
  background-color: white;
}
