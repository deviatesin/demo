/* 主页样式 */
.container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.background-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  z-index: 0;
}

.background-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background-color: rgba(0, 0, 0, 0.3);
  z-index: 1;
}

.content {
  position: relative;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
  padding-top: 150rpx;
}

.text-center {
  text-align: center;
  margin-bottom: 24rpx;
  margin-top: -192rpx;
}

.text-6xl {
  font-size: 144rpx;  
  font-weight: bold;
  color: white;
  margin-bottom: 24rpx;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.text-xl {
  font-size: 32rpx;
  color: white;
  text-shadow: 0 2rpx 4rpx rgba(0, 0, 0, 0.5);
}

.space-y-6 {
  width: 100%;
  max-width: 400rpx;
  padding: 0 32rpx;
  display: flex;
  flex-direction: column;
  gap: 36rpx;
  margin-top: 128rpx;
}

.bg-green-600 {
  background-color: rgba(5, 150, 105, 0.8);
  color: white;
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.bg-blue-600 {
  background-color: rgba(37, 99, 235, 0.8);
  color: white;
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.bg-purple-600 {
  background-color: rgba(124, 58, 237, 0.8);
  color: white;
  backdrop-filter: blur(8rpx);
  border: 1rpx solid rgba(255, 255, 255, 0.2);
}

.hover-bg-green-700:hover {
  background-color: #047857;
}

.hover-bg-blue-700:hover {
  background-color: #1d4ed8;
}

.hover-bg-purple-700:hover {
  background-color: #6d28d9;
}

.text-white {
  color: white;
}

.font-semibold {
  font-weight: 600;
}

.py-4 {
  padding-top: 4rpx;
  padding-bottom: 4rpx;
}

.px-6 {
  padding-left: 6rpx;
  padding-right: 6rpx;
}

.rounded-lg {
  border-radius: 12rpx;
}

.shadow-lg {
  box-shadow: 0 10rpx 15rpx -3rpx rgba(0, 0, 0, 0.1), 0 4rpx 6rpx -2rpx rgba(0, 0, 0, 0.05);
}

.transition {
  transition: all 0.3s ease;
}

.duration-300 {
  transition-duration: 300ms;
}

.flex {
  display: flex;
}

.items-center {
  align-items: center;
}

.justify-center {
  justify-content: center;
}

.space-x-3 {
  gap: 12rpx;
}

.text-lg {
  font-size: 40rpx;
}

.h-6 {
  height: 24rpx;
}

.w-6 {
  width: 24rpx;
}

.w-full {
  width: 100%;
}

.max-w-md {
  max-width: 480rpx;
}

.px-4 {
  padding-left: 16rpx;
  padding-right: 16rpx;
}

.mb-12 {
  margin-bottom: 48rpx;
}

.mb-4 {
  margin-bottom: 16rpx;
}