<view class="container">
  <view class="login-form">
    <text class="title">教师身份验证</text>
    
    <!-- 账号输入框 -->
    <view class="form-item">
      <text class="label">账号</text>
      <input 
        class="input" 
        placeholder="请输入账号" 
        value="{{username}}" 
        bindinput="handleUsernameInput"
      />
    </view>
    
    <!-- 密码输入框 -->
    <view class="form-item">
      <text class="label">密码</text>
      <input 
        class="input" 
        placeholder="请输入密码" 
        value="{{password}}" 
        bindinput="handlePasswordInput"
        password="true"
      />
    </view>
    
    <!-- 错误提示 -->
    <view wx:if="{{errorMessage}}" class="error-message">
      {{errorMessage}}
    </view>
    
    <!-- 登录按钮 -->
    <button 
      class="login-button" 
      bindtap="handleLogin"
    >
      登录
    </button>
  </view>
</view>