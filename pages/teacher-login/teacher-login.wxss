.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  background-color: #F7F7F7;
  min-height: 100vh;
}

.login-form {
  width: 80%;
  max-width: 400rpx;
  background-color: #FFFFFF;
  border-radius: 12rpx;
  padding: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.1);
}

.title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
  text-align: center;
  margin-bottom: 40rpx;
}

.form-item {
  margin-bottom: 30rpx;
}

.label {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 10rpx;
}

.input {
  width: 100%;
  height: 60rpx;
  border: 2rpx solid #E5E5E5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.input:focus {
  border-color: #3498DB;
  outline: none;
}

.error-message {
  font-size: 24rpx;
  color: #E74C3C;
  margin-bottom: 20rpx;
  text-align: center;
}

.login-button {
  width: 100%;
  height: 70rpx;
  background-color: #3498DB;
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 8rpx;
  margin-top: 20rpx;
}

.login-button:hover {
  background-color: #2980B9;
}

.login-button:active {
  background-color: #1F618D;
}