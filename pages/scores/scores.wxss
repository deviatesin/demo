/* 成绩查询页面样式 */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  background-color: #7c3aed;
  color: white;
  padding: 16rpx;
}

.flex {
  display: flex;
}

.items-center {
  align-items: center;
}

.mr-4 {
  margin-right: 16rpx;
}

.p-2 {
  padding: 8rpx;
}

.hover-bg-purple-700:hover {
  background-color: #6d28d9;
}

.rounded-lg {
  border-radius: 12rpx;
}

.transition {
  transition: all 0.3s ease;
}

.duration-200 {
  transition-duration: 200ms;
}

.text-2xl {
  font-size: 32rpx;
}

