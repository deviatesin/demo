<view class="page-container">
  <view class="nav-bar bg-purple-600 text-white p-4">
    <view class="flex items-center">
      <button
        bindtap="navigateBack"
        class="mr-4 p-2 hover:bg-purple-700 rounded-lg transition duration-200"
      >
        <text class="text-white">←</text>
      </button>
      <text class="text-2xl font-bold">成绩查询</text>
    </view>
  </view>

  <view class="p-6">
    <view class="max-w-4xl mx-auto">
      <!-- 搜索区域 -->
      <view class="bg-white rounded-lg shadow-md p-6 mb-6">
        <text class="text-xl font-semibold text-gray-800 mb-4">学生成绩查询</text>
        
        <view class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-6">
          <view>
            <text class="block text-sm font-medium text-gray-700 mb-2">
              学号
            </text>
            <input
              type="text"
              value="{{studentId}}"
              bindinput="handleStudentIdChange"
              bindconfirm="handleSearch"
              placeholder="请输入学号"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent"
            />
          </view>
          
          <view>
            <text class="block text-sm font-medium text-gray-700 mb-2">
              姓名
            </text>
            <input
              type="text"
              value="{{name}}"
              bindinput="handleNameChange"
              bindconfirm="handleSearch"
              placeholder="请输入姓名"
              class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-purple-500 focus:border-transparent"
            />
          </view>
        </view>
        
        <view class="text-center">
          <button
            bindtap="handleSearch"
            class="bg-purple-600 hover:bg-purple-700 text-white font-semibold py-2 px-8 rounded-lg transition duration-200 flex items-center space-x-2 mx-auto"
          >
            <text>🔍</text>
            <text>查询成绩</text>
          </button>
        </view>
      </view>

      <!-- 搜索结果 -->
      <block wx:if="{{hasSearched}}">
        <view class="bg-white rounded-lg shadow-md overflow-hidden">
          <view class="p-6 border-b border-gray-200">
            <text class="text-xl font-bold text-gray-800">查询结果</text>
            <block wx:if="{{searchResults.length > 0}}">
              <text class="text-sm text-gray-600 mt-1">
                找到 {{searchResults.length}} 条成绩记录
              </text>
            </block>
          </view>
          
          <block wx:if="{{searchResults.length === 0}}">
            <view class="p-8 text-center">
              <text class="text-6xl mb-4">🏆</text>
              <text class="text-lg font-semibold text-gray-600 mb-2">未找到相关成绩记录</text>
              <text class="text-gray-500">请检查学号和姓名是否正确</text>
            </view>
          </block>
          
          <block wx:else>
            <view class="divide-y divide-gray-200">
              <block wx:for="{{searchResults}}" wx:key="index">
                <view class="p-6 hover:bg-gray-50 transition duration-200">
                  <view class="flex items-center justify-between">
                    <view class="flex-1">
                      <view class="flex items-center space-x-4 mb-2">
                        <text class="text-lg font-semibold text-gray-800">
                          {{item.examSubject}}
                        </text>
                        <text class="text-sm text-gray-500">
                          学号: {{item.studentId}}
                        </text>
                      </view>
                      
                      <view class="flex items-center text-sm text-gray-600 space-x-6">
                        <text>
                          📅 考试时间: {{item.examTime}}
                        </text>
                        <text>
                          👤 姓名: {{item.name}}
                        </text>
                        <text>
                          📚 科目: {{item.examSubject}}
                        </text>
                      </view>
                    </view>
                    
                    <view class="{{getScoreBackground(item.examScore)}} px-4 py-2 rounded-full">
                      <text class="{{getScoreColor(item.examScore)}} text-2xl font-bold">
                        {{item.examScore}}
                      </text>
                      <text class="text-sm text-gray-500 ml-1">分</text>
                    </view>
                  </view>
                </view>
              </block>
            </view>
          </block>
        </view>
      </block>
    </view>
  </view>
</view>