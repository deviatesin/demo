<view class="page-container">
  <view class="p-6">
    <view class="max-w-4xl mx-auto">
      <!-- 题目内容 -->
      <view class="bg-white rounded-lg shadow-md overflow-hidden mb-6">
        <view class="p-6 bg-green-100 border-l-4 border-green-500">
          <text class="text-lg font-semibold text-gray-800 mb-4 block">
            {{currentIndex + 1}}. {{currentQuestion.question}}
          </text>
        </view>
      </view>

      <!-- 查看答案按钮 -->
      <button
        bindtap="toggleAnswer"
        class="bg-green-100 border-l-4 border-green-500 hover:bg-green-200 text-gray-800 font-semibold py-3 px-6 rounded-lg transition duration-200 mb-6 w-full text-left"
      >
        {{showAnswer ? '隐藏答案' : '查看答案'}}
      </button>

      <!-- 答案表格 -->
      <view wx:if="{{showAnswer}}" class="mb-6 border border-gray-200 rounded-lg overflow-hidden">
        <block wx:for="{{currentQuestion.stages}}" wx:key="stageId">
          <view class="flex">
            <!-- 左侧阶段名称 -->
            <view class="bg-blue-50 p-3 border-r border-gray-200 flex items-center justify-center" style="width: 40rpx;">
              <text class="font-semibold" style="writing-mode: vertical-rl; text-orientation: upright; letter-spacing: 4rpx;">{{item.stageName}}</text>
            </view>
            <!-- 右侧操作步骤 -->
            <view class="flex-1 bg-white">
              <block wx:for="{{item.operations}}" wx:key="operationId" wx:for-item="op" wx:for-index="opIndex">
                <view class="p-1 border-b border-gray-200" wx:if="{{opIndex < item.operations.length - 1}}">
                  <text class="block">{{op.operationName}}</text>
                </view>
                <view class="p-1" wx:else>
                  <text class="block">{{op.operationName}}</text>
                </view>
              </block>
            </view>
          </view>
        </block>
      </view>

      <!-- 页码和导航按钮 -->
      <view class="flex items-center justify-between mb-6">
        <button
          bindtap="prevQuestion"
          disabled="{{currentIndex === 0}}"
          class="bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold py-2 px-4 rounded-lg transition duration-200 {{currentIndex === 0 ? 'opacity-50 cursor-not-allowed' : ''}}"
        >
          上一题
        </button>
        <text class="text-gray-600 font-semibold">{{currentIndex + 1}}/{{trainingData.questionCount}}</text>
        <button
          bindtap="nextQuestion"
          disabled="{{currentIndex === trainingData.questionCount - 1}}"
          class="bg-gray-100 hover:bg-gray-200 text-gray-800 font-semibold py-2 px-4 rounded-lg transition duration-200 {{currentIndex === trainingData.questionCount - 1 ? 'opacity-50 cursor-not-allowed' : ''}}"
        >
          下一题
        </button>
      </view>
    </view>
  </view>
</view>