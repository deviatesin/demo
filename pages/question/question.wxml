<view class="page-container">
  <view class="nav-bar bg-green-600 text-white p-4">
    <view class="flex items-center">
      <button
        bindtap="navigateBack"
        class="mr-4 p-2 hover:bg-green-700 rounded-lg transition duration-200"
      >
        <text class="text-white">←</text>
      </button>
      <text class="text-2xl font-bold">训练题目</text>
    </view>
  </view>

  <view class="p-6">
    <view class="max-w-4xl mx-auto">
      <!-- 题目内容 -->
      <view class="bg-white rounded-lg shadow-md p-6 mb-6">
        <view class="mb-6">
          <text class="text-lg font-semibold text-gray-800 mb-2">
            {{currentQuestion.question}}
          </text>
          <text class="text-sm text-gray-600">
            分类: {{currentQuestion.category1}}
            <text wx:if="{{currentQuestion.category2}}">
              / {{currentQuestion.category2}}
            </text>
          </text>
        </view>

        <view class="mb-6">
          <text class="text-sm font-medium text-gray-700 mb-2 block">
            评分标准
          </text>
          <text class="text-gray-600">
            {{currentQuestion.scoringCriteria}}
          </text>
        </view>

        <view class="border-t border-gray-200 pt-4">
          <text class="text-sm font-medium text-gray-700 mb-2 block">
            参考答案
          </text>
          <text class="text-gray-600">
            {{currentQuestion.answer}}
          </text>
        </view>
      </view>

      <!-- 题目导航 -->
      <view class="flex justify-between items-center">
        <button
          bindtap="prevQuestion"
          disabled="{{currentIndex === 0}}"
          class="bg-gray-600 hover:bg-gray-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 disabled:opacity-50"
        >
          上一题
        </button>
        <text class="text-gray-600">
          {{currentIndex + 1}} / {{questions.length}}
        </text>
        <button
          bindtap="nextQuestion"
          disabled="{{currentIndex === questions.length - 1}}"
          class="bg-green-600 hover:bg-green-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 disabled:opacity-50"
        >
          下一题
        </button>
      </view>
    </view>
  </view>
</view>