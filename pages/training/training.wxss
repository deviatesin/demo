/* 训练模式页面样式 */
.page-container {
  min-height: 100vh;
  background-color: #f5f5f5;
}

.nav-bar {
  background-color: #059669;
  color: white;
  padding: 16rpx;
}

.flex {
  display: flex;
}

.items-center {
  align-items: center;
}

.mr-4 {
  margin-right: 16rpx;
}

.p-2 {
  padding: 8rpx;
}

.hover-bg-green-700:hover {
  background-color: #047857;
}

.rounded-lg {
  border-radius: 12rpx;
}

.transition {
  transition: all 0.3s ease;
}

.duration-200 {
  transition-duration: 200ms;
}

.text-2xl {
  font-size: 32rpx;
}

.font-bold {
  font-weight: bold;
}

.p-6 {
  padding: 24rpx;
}

.space-y-4 {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bg-white {
  background-color: white;
}

.rounded-lg {
  border-radius: 12rpx;
}

.shadow-md {
  box-shadow: 0 4rpx 6rpx -1rpx rgba(0, 0, 0, 0.1), 0 2rpx 4rpx -1rpx rgba(0, 0, 0, 0.06);
}

.overflow-hidden {
  overflow: hidden;
}

.bg-green-50 {
  background-color: #f0fdf4;
}

.border-l-4 {
  border-left: 16rpx solid;
}

.border-green-600 {
  border-color: #059669;
}

.cursor-pointer {
  cursor: pointer;
}

.hover-bg-green-100:hover {
  background-color: #dcfce7;
}

.justify-between {
  justify-content: space-between;
}

.text-lg {
  font-size: 32rpx;
}

.font-semibold {
  font-weight: 600;
}

.text-gray-800 {
  color: #1f2937;
}

.text-gray-500 {
  color: #6b7280;
}

.text-sm {
  font-size: 24rpx;
}

.border-t {
  border-top: 2rpx solid;
}

.border-gray-200 {
  border-color: #e5e7eb;
}

.p-3 {
  padding: 12rpx;
}

.pl-8 {
  padding-left: 32rpx;
}

.hover-bg-gray-50:hover {
  background-color: #f9fafb;
}

.border-b {
  border-bottom: 2rpx solid;
}

.border-gray-100 {
  border-color: #f3f4f6;
}

.last-border-b-0:last-child {
  border-bottom: none;
}

.text-gray-700 {
  color: #374151;
}

.text-gray-400 {
  color: #9ca3af;
}